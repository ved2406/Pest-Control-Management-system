## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Visual Studio / Visual Studio Code
.vs/
.vscode/
*.user
*.userosscache
*.sln.docstates
*.sln.iml
*.code-workspace
.DS_Store

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/
.vscode/

# Test Results
TestResults/
*.trx

# NuGet
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets

# ReSharper
.idea/
*.sln.iml
riderModule.iml
*.rider.yml

# User-specific files
*.suo
*.sln.docstates

# Node modules (if using npm/webpack)
node_modules/

# Environment files
.env
.env.local
